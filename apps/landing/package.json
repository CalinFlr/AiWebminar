{
  "name": "@aiwebminar/landing",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-dist.mjs",
    "check:clean-tracked": "node scripts/check-clean-tracked.mjs",
    "check:deploy-clean": "node scripts/check-clean-tracked.mjs",
    "check:dist": "node scripts/check-dist-public.mjs",
    "check:maturity": "node scripts/check-maturity.mjs",
    "check:wrangler": "npm run build && wrangler pages dev dist --compatibility-date=2026-04-28",
    "predeploy:cloudflare": "npm run build && npm run check:dist && npm run test:security && npm run check:deploy-clean",
    "deploy:cloudflare": "wrangler pages deploy dist --project-name=aiwebminar --commit-dirty=true",
    "ops:local": "npm run preview:emails && node scripts/ops-local-server.mjs",
    "preview:emails": "node scripts/preview-emails.mjs",
    "reconcile:stripe": "node scripts/reconcile-stripe-fulfillments.mjs",
    "test:security": "node tests/security-smoke.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.84.1"
  }
}
