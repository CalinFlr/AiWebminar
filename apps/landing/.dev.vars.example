# Copy to .dev.vars.local for local ops or .dev.vars for wrangler pages dev.
# Do not commit real secret values.

# Public/runtime config
PUBLIC_SITE_URL=http://127.0.0.1:8788
WORKSHOP_STATUS=tbd
WORKSHOP_LIVE_URL=
EXPECTED_VIP_AMOUNT=10000
EXPECTED_VIP_CURRENCY=ron
GA4_MEASUREMENT_ID=
META_PIXEL_ID=

# Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stripe checkout and server verification
STRIPE_PAYMENT_LINK_URL=
STRIPE_PAYMENT_LINK_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RECONCILE_CREATED_GTE=

# Protected ops/API access
ADMIN_EXPORT_TOKEN=
OPS_ADMIN_EXPORT_TOKEN=
OPS_REMOTE_BASE_URL=https://aiwebminar.pages.dev
OPS_PORT=8789

# Optional Make webhooks
MAKE_LEAD_WEBHOOK_URL=
MAKE_ONBOARDING_WEBHOOK_URL=
MAKE_PAYMENT_WEBHOOK_URL=

# Optional Google Apps Script ops webhook
GOOGLE_OPS_WEBHOOK_URL=
GOOGLE_OPS_WEBHOOK_SECRET=

# WhatsApp group access URLs
WHATSAPP_FREE_GROUP_URL=
WHATSAPP_VIP_GROUP_URL=

# Public write rate limits
RATE_LIMIT_SALT=
RATE_LIMIT_WINDOW_SECONDS=900
LEAD_RATE_LIMIT_IP=30
LEAD_RATE_LIMIT_EMAIL=5
ONBOARDING_RATE_LIMIT_IP=40
ONBOARDING_RATE_LIMIT_EMAIL=10
ONBOARDING_RATE_LIMIT_LEAD=5

# Local WhatsApp Web driver for ops
WA_WEB_CHROME_PATH=
WA_WEB_CHROME_PROFILE=
WA_WEB_CDP_PORT=
WA_WEB_HUMAN=1
WA_WEB_DELAY_MIN=120
WA_WEB_DELAY_MAX=420
WA_WEB_KEY_DELAY_MIN=18
WA_WEB_KEY_DELAY_MAX=75
WA_1TO1_COOLDOWN_MS=10000

# Local-only SMS Gateway, used by npm run ops:local
SMS_GATEWAY_URL=
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PASSWORD=
SMS_GATEWAY_MESSAGES_PATH=/messages
SMS_GATEWAY_TIMEOUT_MS=45000
SMS_GATEWAY_COOLDOWN_MS=15000
